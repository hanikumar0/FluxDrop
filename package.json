{
  "name": "fluxdrop-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:push": "turbo run db:push",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "prisma": "^7.8.0",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/swagger": "^11.4.2",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.7",
    "mongoose": "^9.6.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3"
  }
}
