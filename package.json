{
  "name": "fluxdrop",
  "private": true,
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "concurrently -n \"AUTH,ORDER,PAY,RESTAURANT,DELIVERY,NOTIFY,GATEWAY\" -c \"blue,green,magenta,yellow,cyan,white,red\" \"npm run dev -w auth-service\" \"npm run dev -w order-service\" \"npm run dev -w payment-service\" \"npm run dev -w restaurant-service\" \"npm run dev -w delivery-service\" \"npm run dev -w notification-service\" \"npm run dev -w api-gateway\"",
    "dev:admin": "npm run dev --workspace=@fluxdrop/admin-app",
    "dev:customer": "npm run dev --workspace=@fluxdrop/customer-app",
    "dev:delivery": "npm run dev --workspace=@fluxdrop/delivery-app",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "npm run check-types --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.7.4",

    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "server/services/*",
    "server/shared/*",
    "server/gateway",
    "server/websocket",
    "server/workers",
    "server/jobs",
    "customer-app",
    "delivery-app",
    "admin-app"
  ],
  "dependencies": {
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/swagger": "^11.4.2",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.7",
    "mongoose": "^9.6.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3"
  }
}
